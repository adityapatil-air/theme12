# ─────────────────────────────────────────────────────────────────────────
# Pratyaya — Railway environment variables
# ─────────────────────────────────────────────────────────────────────────
# Paste these into Railway → your service → Variables tab. Do NOT commit
# this file with real values; it lives here only as a reference template.
#
# After your first successful deploy, come back and set PUBLIC_BASE_URL
# to whatever Railway gave you (e.g. https://pratyaya-production.up.railway.app).
# ─────────────────────────────────────────────────────────────────────────

# ── Groq Cloud (required) ────────────────────────────────────────────────
# Get a fresh key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Models — keep these defaults unless you know what you're doing.
ASR_MODEL=whisper-large-v3
LLM_MODEL=llama-3.3-70b-versatile
LLM_FAST_MODEL=llama-3.1-8b-instant

# ── Database (REQUIRED — must be postgres on Railway) ───────────────────
# Railway's filesystem is ephemeral; SQLite would be wiped on every redeploy.
# Use the Supabase Postgres database you already have set up.
DB_BACKEND=postgres
SUPABASE_DB_HOST=db.YOUR-PROJECT.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Optional Supabase REST keys (not strictly needed for the demo).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram (optional but recommended for the demo) ─────────────────────
# 1. Open Telegram, message @BotFather, send /newbot → copy token
# 2. Open Telegram, message @userinfobot → copy your numeric ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Public base URL ──────────────────────────────────────────────────────
# Set AFTER first deploy, to whatever Railway shows you. No trailing slash.
# Used for Telegram handover links pointing the officer to the live agent.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# ── Server bind ──────────────────────────────────────────────────────────
# Railway sets PORT automatically — do NOT override it.
# HOST=0.0.0.0   ← already the default

# ── Debug toggles (leave OFF in production) ──────────────────────────────
# Defaults to 0 since the Railway filesystem is ephemeral.
PRATYAYA_DEBUG_AUDIO=0
